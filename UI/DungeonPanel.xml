                    </Frame>
                    <Frame parentKey="BLFit" inherits="PremadeGroupsFilterBasicTemplate">
                        <Anchors>
                            <Anchor point="TOPLEFT" relativeKey="$parent.Partyfit" relativePoint="BOTTOMLEFT"/>
